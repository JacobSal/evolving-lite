_graph/cache/delegation-fitness.json
_graph/cache/lens-fitness.json
_graph/cache/trait-fitness.json
*.lock

# Steward runtime (findings/markers/archives accrue from the user's own sessions;
# steward-config.json ships, everything else is generated). Cold-data.
_inbox/steward-findings.jsonl
_inbox/steward-actions-pending.jsonl
_graph/cache/steward-audit-marker.json
_graph/cache/steward-retirement-marker.json
_archive/
_autonomous/

# AutoEvolve runtime data (accumulates from the user's own sessions; cold-data).
# Schema files (config.json, baselines.json, test-cases/, .mutation-habituation.json)
# ship empty; only the pure-accumulation ledgers + snapshots are user data.
_autoevolve/outcomes/*.jsonl
_autoevolve/rejected/*.json
_autoevolve/snapshots/
!_autoevolve/outcomes/.gitkeep
!_autoevolve/rejected/.gitkeep

# Autonomy lease + stop-gate observations (runtime, cold-data)
_graph/cache/autonom-lease.json
_ledgers/stop-gate-observations.jsonl
