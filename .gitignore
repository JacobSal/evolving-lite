_memory/experiences/_prewarmed/exp-*.json

# Shared temp namespace (sentinels, session-scoped guard/marker files).
# Pinned to <plugin_root>/_runtime so bash and Python hooks agree on one
# location cross-platform (see common.py evolving_tmp_dir). Pure runtime data.
_runtime/
/tmp/evolving-lite-*

# Auto-generated by Evolving hooks (not part of plugin)
knowledge/explorations/
knowledge/executions/
knowledge/research/
_memory/routing/
_memory/archives/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# Runtime graph caches (generated from the user's own sessions; cold-data)
_graph/cache/coactivation.json
_graph/cache/hot-pairs.json
