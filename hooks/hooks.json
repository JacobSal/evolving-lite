{
  "description": "Evolving Lite hook registrations - all tiers registered, tier gates enforced inside each script",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/health-sentinel.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/doctor.py --session-start",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/graph/coactivation-aggregator.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/graph/compute-hot-pairs.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/graph/synthesis-detector.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/graph/auto-edges.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/graph/auto-routes.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/recalc-fitness.py --trigger session-start",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/steward-checker.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/security-tier-check.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/context-warning.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/thinking-recall.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/delegation-outcome-tracker.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/correction-detector.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 /c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/delegation-enforcer.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|Task|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/usage-tracker.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/artifact-registration-enforcer.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "WebFetch|mcp__firecrawl__firecrawl_scrape|mcp__firecrawl__firecrawl_search|mcp__firecrawl__firecrawl_extract|mcp__firecrawl__firecrawl_crawl|mcp__firecrawl__firecrawl_agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/content-scanner.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/precompact-extract.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/session-summary.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 /c/Users/jsalm/Documents/GitHub/llm_resume_writer/submodules/evolving-lite/hooks/scripts/auto-archival.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/delegation-outcome-tracker.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/forced-verify-stop-gate.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
